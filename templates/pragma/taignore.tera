# .taignore — Files excluded from TA draft staging
# Generated by `ta init`

# TA staging and internal files (local — NOT committed)
.ta/staging/
.ta/sessions/
.ta/memory/
.ta/review/
# .ta/project-memory/ is intentionally NOT listed here — it is committed to VCS.

# Pragma Engine / Gradle
build/
.gradle/
**/build/
**/.gradle/
*.class
.idea/
*.iml

# IDE and OS
.idea/
.vscode/
*.swp
.DS_Store
