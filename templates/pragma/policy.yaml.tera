# TA Policy Configuration
# Generated by `ta init` for pragma-kotlin project

security_level: checkpoint

defaults:
  enforcement: error
  auto_approve:
    verbs:
      - read
      - list
      - search

schemes:
  fs:
    auto_approve_verbs:
      - read
      - list

escalation:
  drift_threshold: 0.7
  action_limit: 100

protected_paths:
  - "pragma-core/src/main/resources/**"
  - "**/pragma-ext-service/**/*.yaml"
  - "settings.gradle.kts"
  - "settings.gradle"
