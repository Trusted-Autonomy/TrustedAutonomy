#!/usr/bin/env bash
# Helper script to run commands inside the Nix devShell.
# Usage: ./dev cargo test --workspace
# Usage: ./dev just verify
set -euo pipefail

# Warn if target/ is getting large (threshold: 80GB).
# Run 'just clean' to free space; install_local.sh auto-cleans above 150GB.
_TARGET_WARN_GB=80
if [[ -d target ]]; then
    _target_kb=$(du -sk target 2>/dev/null | cut -f1 || echo 0)
    _target_gb=$(( _target_kb / 1048576 ))
    if (( _target_gb >= _TARGET_WARN_GB )); then
        echo "WARNING: target/ is ${_target_gb}GB — run 'just clean' to free space" >&2
    fi
fi

export PATH="/nix/var/nix/profiles/default/bin:$HOME/.nix-profile/bin:$PATH"
exec nix develop --no-warn-dirty --command bash -c "$*"
